{"ast":null,"code":"const RoundFloat=value=>{var value=Math.round(parseFloat(value)*100)/100;var xsd=value.toString().split('.');if(xsd.length==1){value=value.toString()+'.00';return value;}if(xsd.length>1){if(xsd[1].length<2){value=value.toString()+'0';}return value;}};export default RoundFloat;","map":{"version":3,"names":["RoundFloat","value","Math","round","parseFloat","xsd","toString","split","length"],"sources":["/Users/joanzhong/Documents/mllm_git/论文/usb_for_leadboard/src/components/resolveFloat.js"],"sourcesContent":["const RoundFloat = (value) => {\n  var value = Math.round(parseFloat(value) * 100) / 100;\n  var xsd = value.toString().split('.');\n  if (xsd.length == 1) {\n    value = value.toString() + '.00';\n    return value;\n  }\n  if (xsd.length > 1) {\n    if (xsd[1].length < 2) {\n      value = value.toString() + '0';\n    }\n    return value;\n  }\n};\nexport default RoundFloat;\n"],"mappings":"AAAA,KAAM,CAAAA,UAAU,CAAIC,KAAK,EAAK,CAC5B,GAAI,CAAAA,KAAK,CAAGC,IAAI,CAACC,KAAK,CAACC,UAAU,CAACH,KAAK,CAAC,CAAG,GAAG,CAAC,CAAG,GAAG,CACrD,GAAI,CAAAI,GAAG,CAAGJ,KAAK,CAACK,QAAQ,EAAE,CAACC,KAAK,CAAC,GAAG,CAAC,CACrC,GAAIF,GAAG,CAACG,MAAM,EAAI,CAAC,CAAE,CACnBP,KAAK,CAAGA,KAAK,CAACK,QAAQ,EAAE,CAAG,KAAK,CAChC,MAAO,CAAAL,KAAK,CACd,CACA,GAAII,GAAG,CAACG,MAAM,CAAG,CAAC,CAAE,CAClB,GAAIH,GAAG,CAAC,CAAC,CAAC,CAACG,MAAM,CAAG,CAAC,CAAE,CACrBP,KAAK,CAAGA,KAAK,CAACK,QAAQ,EAAE,CAAG,GAAG,CAChC,CACA,MAAO,CAAAL,KAAK,CACd,CACF,CAAC,CACD,cAAe,CAAAD,UAAU"},"metadata":{},"sourceType":"module","externalDependencies":[]}